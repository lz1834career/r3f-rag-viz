{
  "name": "r3f-rag-viz-react",
  "version": "0.1.0",
  "description": "React Three Fiber components for editable 3D RAG knowledge graphs",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lz1834career/r3f-rag-viz.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/lz1834career/r3f-rag-viz#readme",
  "bugs": {
    "url": "https://github.com/lz1834career/r3f-rag-viz/issues"
  },
  "keywords": [
    "rag",
    "react-three-fiber",
    "threejs",
    "knowledge-graph",
    "visualization",
    "react",
    "3d"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "r3f-rag-viz-core": "^0.1.0"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.160.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@react-three/drei": {
      "optional": false
    }
  },
  "devDependencies": {
    "r3f-rag-viz-core": "0.1.0",
    "@react-three/drei": "^10.0.6",
    "@react-three/fiber": "^9.1.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.176.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.176.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "zustand": "^5.0.5"
  }
}
